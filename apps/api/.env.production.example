NODE_ENV=production

# Render sets PORT automatically. Keep API_PORT only for local parity if needed.
API_PORT=3000

# Supabase Postgres connection string, preferably from Connection Pooler.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DB_SSL=true
DB_SYNCHRONIZE=true

# Render Key Value internal connection string.
REDIS_URL=redis://red-xxxxxxxxxxxxxxxxxxxx:6379

# Exact Vercel production URL. Use comma-separated URLs if you also allow previews.
FRONTEND_URL=https://smartdirect-crm.vercel.app

JWT_SECRET=generate-a-long-random-secret
JWT_EXPIRES_IN=7d

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=sua_senha_app
